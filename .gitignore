/target
Cargo.lock
**/*.rs.bk
*.pdb

# cargo-fuzz build + runtime artifacts (the targets + fuzz/Cargo.toml are tracked;
# the compiled corpus, coverage, crash artifacts, and build tree are not).
/fuzz/target
/fuzz/corpus
/fuzz/artifacts
/fuzz/coverage

# SBTDD + agent local artifacts (local to each developer, never tracked)
CLAUDE.local.md
CLAUDE.md
.claude/
sbtdd/
planning/

# Dev-only tooling, not part of the publishable crate. Canonical copy lives in
# ~/BolivarTech/AI_Tools/ for reuse across repos.
/scripts/graphify_ollama.py
/scripts/claude_usage.py
/scripts/sleep_signal.py
claude-usage*.txt
run-tests.py
patch_graphify_hooks.py

# Python bytecode/caches from dev scripts
__pycache__/
*.pyc

# Graphify: commit graphify-out/ to share the knowledge graph, but keep
# local-only / machine-specific artifacts out (per graphify howto §9).
graphify-out/cost.json
graphify-out/cache/
graphify-out/.graphify_python
graphify-out/20[0-9][0-9]-[0-9][0-9]-[0-9][0-9]/

# Machine-local git-attributes: union-merge for graph.json (graphify howto §6),
# paired with the per-machine, non-versioned graphify git hooks (§9).
.gitattributes
